{
  "name": "@poker5o/server",
  "version": "1.0.0",
  "private": true,
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist",
    "reset-db": "tsx scripts/reset-db.ts",
    "reset-db:yes": "tsx scripts/reset-db.ts --yes"
  },
  "dependencies": {
    "@poker5o/shared": "*",
    "@supabase/supabase-js": "^2.43.0",
    "dotenv": "^16.4.0",
    "cors": "^2.8.5",
    "express": "^4.19.0",
    "ioredis": "^5.3.2",
    "socket.io": "^4.7.5",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/uuid": "^10.0.0",
    "tsx": "^4.11.0",
    "typescript": "^5.4.0"
  }
}
